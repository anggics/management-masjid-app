APP_NAME="Mushola Mujahadah"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://your-app.up.railway.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_HOST=
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@masjid.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- Jadwal Sholat (Aladhan API) ---
ALADHAN_BASE_URL=https://api.aladhan.com/v1
PRAYER_CITY=Jakarta
PRAYER_COUNTRY=Indonesia
# Metode 20 = Kementerian Agama Republik Indonesia (Kemenag)
PRAYER_METHOD=20

# --- Penyimpanan media (default lokal; isi untuk pakai Cloudinary) ---
CLOUDINARY_URL=

# --- Firebase Cloud Messaging (push notif) — isi saat produksi ---
FCM_SERVER_KEY=
FCM_PROJECT_ID=
